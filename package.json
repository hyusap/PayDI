{
  "name": "adistripe",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:widget": "bun run --cwd packages/widget build",
    "build:dashboard": "bun run --cwd packages/dashboard build",
    "dev:api": "bun run --cwd packages/api dev",
    "dev:dashboard": "bun run --cwd packages/dashboard dev",
    "dev:testsite": "bun run --cwd packages/testsite dev",
    "test:contracts": "cd packages/contracts && forge test"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
