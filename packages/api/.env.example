# API server
PORT=3000
API_URL=http://localhost:3000

# ADI Chain
TESTNET_RPC=https://rpc.ab.testnet.adifoundation.ai/
MAINNET_RPC=https://rpc.adifoundation.ai/
CHAIN_ID=99999

# Deployed contract address (after forge deploy)
PAYMENT_PROCESSOR_ADDRESS=0x0000000000000000000000000000000000000000

# Backend wallet (used to call createSession on-chain)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# SQLite database path
DB_PATH=./adipay.db

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# Optional USD->AED conversion rate used for price quoting
USD_AED_RATE=3.67
